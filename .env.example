NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# App origin used for auth email confirmation links (e.g. http://localhost:3000).
# Falls back to the request Origin header when unset.
NEXT_PUBLIC_SITE_URL=

# NOTE: never put real secrets in this tracked template. Put them in .env.local
# (git-ignored). The app does not use a raw DB password — only the Supabase URL +
# anon/service keys above. For direct DB access (e.g. `supabase db push`), keep the
# connection string/password in .env.local only.